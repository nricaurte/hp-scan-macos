--- a/scan/sane/hpaio.c
+++ b/scan/sane/hpaio.c
@@ -377,8 +377,12 @@ extern SANE_Status sane_hpaio_get_devices(const SANE_Device ***deviceList, SANE_
    DBG(8, "sane_hpaio_get_devices(local=%d): %s %d\n", localOnly, __FILE__, __LINE__);
    ResetDeviceList(&DeviceList);
    DevDiscovery(localOnly);
    *deviceList = (const SANE_Device **)DeviceList;
+#ifndef __APPLE__
+   /* The original code passes an uninitialized pointer here; on Linux this
+    * happens to work because the orblite path is rarely taken. Skip on macOS
